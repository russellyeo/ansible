.:53 {
    # Handle requests for the main tailnet domain and subdomains
    template IN A {{ coredns_domain }} {
        match ^([^.]+)\.{{ coredns_domain | regex_escape }}\.$
        answer "{{ "{{" }} .Name {{ "}}" }} 60 IN A {{ coredns_ip }}"
        fallthrough
    }
    
    # Handle the main domain
    hosts {
        {{ coredns_ip }} {{ coredns_domain }}
        {% for subdomain in coredns_subdomains %}
        {{ subdomain.ip }} {{ subdomain.name }}.{{ coredns_domain }}
        {% endfor %}
        fallthrough
    }
    
    # Forward all other queries to upstream DNS
    forward . {{ upstream_dns_primary }} {{ upstream_dns_secondary }}
    
    # Cache responses
    cache 30
    
    # Enable logging
    log
    
    # Enable error logging
    errors
}